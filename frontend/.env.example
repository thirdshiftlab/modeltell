# Frontend build-time config (Vite). Copy to frontend/.env and fill in.

# Newsletter popup → Brevo. This is Brevo's PUBLIC form-submission URL, NOT an
# API key — it's safe in the client. Get it from Brevo:
#   Contacts → Forms → (create/select a form) → Share → the <form action="…"> URL.
# Looks like: https://sibforms.com/serve/MUIFxxxxxxxxxxxxxxxx
# If unset, the popup still shows but submitting does nothing (logs a warning).
VITE_BREVO_FORM_URL=

# Optional: drop your Third Shift Lab logo at frontend/public/thirdshiftlab-logo.svg
# and the popup uses it automatically (otherwise it falls back to a wordmark).

# Umami analytics (self-hosted, cookieless). Leave the ID empty to disable.
# Create a website in Umami → Settings → Websites to get the ID (a UUID).
# Serve the script from your own subdomain for first-party/ad-blocker-resilient
# delivery (see README "Analytics" — it's a DNS + reverse-proxy step, not an
# Umami setting). VITE_UMAMI_SRC defaults to https://analytics.modeltell.com/script.js
VITE_UMAMI_WEBSITE_ID=
VITE_UMAMI_SRC=https://analytics.modeltell.com/script.js
