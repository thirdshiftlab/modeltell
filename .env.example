# Modeltell - API Keys
# Copy to .env and fill in your key.

# ── Required: one key for everything ──
# The default registry (src/runner/models.ts) routes ALL models through
# OpenRouter's single OpenAI-compatible API, so this one key is all you need.
OPENROUTER_API_KEY=sk-or-...

# ── Advanced: direct provider keys ──
# Only consulted if you change a model's `provider` in models.ts away from
# "openrouter". With the default registry these are NOT used - leave them unset.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AI...
# TOGETHER_API_KEY=...
# MISTRAL_API_KEY=...

# ── Optional knobs ──
# Fast smoke run: 1 generation per prompt instead of 3:
# RUNS_PER_PROMPT=1
# Run only specific models (comma-separated):
# ONLY_MODELS=claude-sonnet-4.6,gpt-5.5
# Corpus language: "en" (default) or "de" - picks prompts/catalog[.de].json,
# the system prompt, German stopwords, and patterns/definitions[.de].json.
# Set it for the whole pipeline (run + analyze + publish):
# LOCALE=de
